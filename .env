# ========================
# FITPLAN.AI BACKEND CONFIG
# ========================

# MongoDB Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/database_name

# Database Name
DB_NAME=fitness_app

# JWT Secret Key (Generate: openssl rand -hex 32)
# CRITICAL: Change this in production - generate a strong random key
SECRET_KEY="YOUR KEY"

# Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="YOUR_API_KEY"

# YouTube Data API Key
# Get from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY="YOUR_API_KEY"

